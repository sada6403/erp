{
  "name": "pos-erp",
  "version": "2.0.17",
  "description": "Enterprise Multi Branch Offline-First POS ERP for Furniture & Electronics",
  "main": "dist-electron/main.js",
  "author": "Enterprise POS ERP",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/kill-dev.js",
    "dev": "concurrently \"vite --port 5173 --strictPort\" \"npm:electron-start\"",
    "electron-start": "tsc -p tsconfig.electron.json && wait-on tcp:5173 && node electron-launcher.js",
    "preview-web": "node ./node_modules/vite/bin/vite.js --port 5173",
    "build": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "build:win": "tsc -p tsconfig.electron.json && vite build && electron-builder --win",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^3.3.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "immer": "^10.0.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "nanoid": "^5.0.6",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.1",
    "recharts": "^2.12.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.1"
  },
  "build": {
    "appId": "com.enterprise.pos-erp",
    "productName": "Enterprise POS ERP",
    "directories": {
      "output": "C:\\pos-erp-release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "icon": "assets/icon.ico",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "database/",
        "to": "database/"
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "http://72.61.115.222/updates/"
    }
  }
}
