{
  "name": "pos-erp",
  "version": "2.0.19",
  "description": "Enterprise Multi Branch Offline-First POS ERP for Furniture & Electronics",
  "main": "dist-electron/main.js",
  "author": "Enterprise POS ERP",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/kill-dev.js",
    "dev": "concurrently \"node scripts/vite-dev.mjs\" \"npm:electron-start\"",
    "build:web": "node scripts/vite-build.mjs",
    "preview:web": "node scripts/vite-preview.mjs",
    "electron-start": "tsc -p tsconfig.electron.json && wait-on tcp:5173 && node electron-launcher.js",
    "preview-web": "node ./node_modules/vite/bin/vite.js --port 5173",
    "build": "tsc -p tsconfig.electron.json && npm run build:web && electron-builder",
    "build:win": "tsc -p tsconfig.electron.json && npm run build:web && electron-builder --win",
    "preview": "npm run preview:web",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "happy-dom": "^15.11.7",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^3.3.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "immer": "^10.0.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "nanoid": "^5.0.6",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.1",
    "recharts": "^2.12.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.1"
  },
  "build": {
    "appId": "com.enterprise.pos-erp",
    "productName": "Enterprise POS ERP",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "icon": "assets/icon.ico",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "database/",
        "to": "database/"
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "http://72.61.115.222/updates/"
    }
  }
}
