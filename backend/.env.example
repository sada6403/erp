# MySQL connection (choose one format)
DATABASE_URL=mysql://root:yourpassword@127.0.0.1:3306/pos_erp_saas
# OR use individual vars:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=yourpassword
# MYSQL_DATABASE=pos_erp_saas

CLOUD_API_KEY=replace-with-a-long-random-secret
UPLOAD_DIR=C:/pos-erp-uploads
PUBLIC_BASE_URL=http://localhost:3000
MAX_UPLOAD_BYTES=10485760

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-64-byte-hex-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-64-byte-hex-secret

# ─── Portal URLs (for CORS / redirect) ───────────────────────────────────────
SUPERADMIN_PORTAL_URL=https://superadmin.yourdomain.com
ADMIN_PORTAL_URL=https://admin.yourdomain.com
POS_PORTAL_URL=https://pos.yourdomain.com
